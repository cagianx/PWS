<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PWS.App.Linux.Pages.BrowserPage"
             Title="PWS Browser"
             BackgroundColor="{StaticResource PageBackgroundColor}">

    <Grid RowDefinitions="48,*,22">

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="40,40,40,40,*,70"
              BackgroundColor="{StaticResource ToolbarBackgroundColor}"
              Padding="4,4">

            <!-- Indietro -->
            <Button Grid.Column="0"
                    Text="‹"
                    Command="{Binding GoBackCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    ToolTipProperties.Text="Indietro" />

            <!-- Avanti -->
            <Button Grid.Column="1"
                    Text="›"
                    Command="{Binding GoForwardCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    ToolTipProperties.Text="Avanti" />

            <!-- Ricarica -->
            <Button Grid.Column="2"
                    Text="↻"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    ToolTipProperties.Text="Ricarica" />

            <!-- Interrompi -->
            <Button Grid.Column="3"
                    Text="✕"
                    Command="{Binding StopCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    ToolTipProperties.Text="Interrompi caricamento" />

            <!-- Barra degli indirizzi -->
            <Entry Grid.Column="4"
                   x:Name="AddressEntry"
                   Text="{Binding AddressText, Mode=TwoWay}"
                   ReturnCommand="{Binding NavigateCommand}"
                   ReturnCommandParameter="{Binding AddressText}"
                   Keyboard="Url"
                   VerticalOptions="Center"
                   Margin="4,0"
                   Placeholder="pws://..." />

            <!-- Pulsante Vai -->
            <Button Grid.Column="5"
                    Text="Vai"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="{Binding AddressText}"
                    Style="{StaticResource GoButtonStyle}"
                    Margin="2,0,4,0" />
        </Grid>

        <!-- ── Area contenuto ────────────────────────────────────── -->
        <ContentView Grid.Row="1"
                     x:Name="BrowserHost">
            <Grid BackgroundColor="{StaticResource PageBackgroundColor}">
                <Label Text="Nessuna pagina caricata"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource SecondaryTextColor}" />
            </Grid>
        </ContentView>

        <!-- ── Barra di stato ────────────────────────────────────── -->
        <Label Grid.Row="2"
               Text="{Binding StatusMessage}"
               BackgroundColor="{StaticResource StatusBarBackgroundColor}"
               TextColor="{StaticResource SecondaryTextColor}"
               FontSize="11"
               Padding="8,0"
               VerticalTextAlignment="Center" />

    </Grid>
</ContentPage>

