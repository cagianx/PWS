<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PWS.App.Linux.Pages.ErrorPage"
             Title="Errore">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="12">

        <!-- ── Header ──────────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Spacing="6">

            <Label Text="⚠  Si è verificato un errore"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#CC2222" />

            <Label x:Name="ContextLabel"
                   FontSize="13"
                   TextColor="#666666"
                   IsVisible="False" />

            <Label x:Name="MessageLabel"
                   FontSize="14"
                   FontAttributes="Bold"
                   LineBreakMode="WordWrap" />

            <BoxView HeightRequest="1"
                     BackgroundColor="#CCCCCC"
                     Margin="0,4,0,0" />

            <Label Text="Stack trace:"
                   FontSize="12"
                   TextColor="#888888" />
        </VerticalStackLayout>

        <!-- ── Stack trace (scrollabile) ───────────────────────── -->
        <ScrollView Grid.Row="1">
            <Label x:Name="StackTraceLabel"
                   FontFamily="Monospace"
                   FontSize="11"
                   LineBreakMode="CharacterWrap"
                   TextColor="#333333" />
        </ScrollView>

        <!-- ── Pulsanti ─────────────────────────────────────────── -->
        <HorizontalStackLayout Grid.Row="2"
                               HorizontalOptions="End"
                               Spacing="8">
            <Button x:Name="CopyButton"
                    Text="📋 Copia"
                    Clicked="OnCopyClicked"
                    BackgroundColor="#EEEEEE"
                    TextColor="#333333" />
            <Button Text="Chiudi"
                    Clicked="OnCloseClicked"
                    BackgroundColor="#CC2222"
                    TextColor="White" />
        </HorizontalStackLayout>

    </Grid>
</ContentPage>

