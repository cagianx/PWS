<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Sfondo principale -->
    <Color x:Key="PageBackgroundColor">#FFFFFF</Color>

    <!-- Toolbar del browser -->
    <Color x:Key="ToolbarBackgroundColor">#F0F0F0</Color>

    <!-- Barra di stato in fondo -->
    <Color x:Key="StatusBarBackgroundColor">#E8E8E8</Color>

    <!-- Accento (pulsante Go, focus) -->
    <Color x:Key="PrimaryColor">#0078D4</Color>
    <Color x:Key="PrimaryDarkColor">#005A9E</Color>

    <!-- Testi -->
    <Color x:Key="PrimaryTextColor">#1A1A1A</Color>
    <Color x:Key="SecondaryTextColor">#6B6B6B</Color>

</ResourceDictionary>

